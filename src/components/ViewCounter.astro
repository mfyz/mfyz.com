---
import { SITE } from "@/consts";

export interface Props {
  slug: string;
}

const { slug } = Astro.props;
const gcSite = SITE.goatcounterSite;
const gcEndpoint = `https://${gcSite}.goatcounter.com/count`;
---

<span
  class="view-counter hidden items-center gap-1"
  data-slug={slug}
  data-gc-site={gcSite}
>
  <span class="view-count text-sm"></span>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="1.5"
    stroke="currentColor"
    class="size-5"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"
    ></path>
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
  </svg>
</span>

<!-- GoatCounter count.js for tracking page views -->
<script
  is:inline
  data-goatcounter={gcEndpoint}
  async
  src="//gc.zgo.at/count.js"
></script>

<script>
  function initViewCounters() {
    const el = document.querySelector<HTMLElement>(".view-counter");
    if (!el) return;

    const slug = el.dataset.slug;
    const gcSite = el.dataset.gcSite;
    if (!slug || !gcSite) return;

    const countEl = el.querySelector(".view-count");
    if (!countEl) return;

    // Reset on page transitions
    countEl.textContent = "";
    el.classList.remove("flex");
    el.classList.add("hidden");

    // Fetch count from JSON endpoint: /counter/SLUG.json (no slashes)
    fetch(`https://${gcSite}.goatcounter.com/counter/${slug}.json`)
      .then(r => (r.ok ? r.json() : null))
      .then(data => {
        if (data?.count) {
          countEl.textContent = data.count;
          el.classList.remove("hidden");
          el.classList.add("flex");
        }
      })
      .catch(() => {});
  }

  document.addEventListener("astro:page-load", initViewCounters);
</script>
