---
import { SITE } from "@/consts";

export interface Props {
  slug: string;
}

const { slug } = Astro.props;
const gcSite = SITE.goatcounterSite;
---

<span
  class="view-counter flex items-center gap-1"
  data-slug={slug}
  data-gc-site={gcSite}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="1.5"
    stroke="currentColor"
    class="size-5"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"
    ></path>
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
  </svg>
  <span class="view-count text-sm" style="min-width: 1.5em;"></span>
</span>

<script>
  function initViewCounters() {
    document.querySelectorAll<HTMLElement>(".view-counter").forEach(el => {
      const slug = el.dataset.slug;
      const gcSite = el.dataset.gcSite;
      if (!slug || !gcSite) return;

      const countEl = el.querySelector(".view-count");
      if (!countEl) return;

      const pagePath = `/${slug}/`;
      const baseUrl = `https://${gcSite}.goatcounter.com`;
      const isLocal =
        location.hostname === "localhost" ||
        location.hostname === "127.0.0.1";

      // Fetch current count
      fetch(`${baseUrl}/counter/${encodeURIComponent(pagePath)}.json`)
        .then(r => (r.ok ? r.json() : null))
        .then(data => {
          if (data?.count) {
            countEl.textContent = data.count;
          }
        })
        .catch(() => {});

      // Record view after 10s delay (skip localhost, skip if already counted this session)
      if (!isLocal) {
        const sessionKey = `gc_viewed_${slug}`;
        if (!sessionStorage.getItem(sessionKey)) {
          setTimeout(() => {
            const img = new Image();
            img.src = `${baseUrl}/count?p=${encodeURIComponent(pagePath)}&t=${encodeURIComponent(document.title)}`;
            sessionStorage.setItem(sessionKey, "1");
          }, 10000);
        }
      }
    });
  }

  // Run on initial load and Astro page transitions
  document.addEventListener("astro:page-load", initViewCounters);
</script>
