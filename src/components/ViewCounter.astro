---
import { SITE } from "@/consts";

export interface Props {
  slug: string;
}

const { slug } = Astro.props;
const gcSite = SITE.goatcounterSite;
const gcEndpoint = `https://${gcSite}.goatcounter.com/count`;
---

<span
  class="view-counter hidden items-center gap-1"
  data-slug={slug}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="1.5"
    stroke="currentColor"
    class="size-5"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"
    ></path>
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
  </svg>
  <span class="view-count text-sm"></span>
</span>

<!-- GoatCounter count.js handles both tracking and the visit_count API -->
<script
  is:inline
  data-goatcounter={gcEndpoint}
  async
  src="//gc.zgo.at/count.js"
></script>

<script>
  declare global {
    interface Window {
      goatcounter?: {
        visit_count?: (opts: Record<string, unknown>) => void;
      };
    }
  }

  function initViewCounters() {
    const el = document.querySelector<HTMLElement>(".view-counter");
    if (!el) return;

    const slug = el.dataset.slug;
    if (!slug) return;

    const countEl = el.querySelector(".view-count");
    if (!countEl) return;

    // Clear any previous content (Astro page transitions)
    countEl.innerHTML = "";
    el.classList.remove("flex");
    el.classList.add("hidden");

    // Poll until window.goatcounter is loaded by count.js
    const check = setInterval(() => {
      if (
        typeof window.goatcounter === "undefined" ||
        typeof window.goatcounter.visit_count === "undefined"
      ) {
        return;
      }
      clearInterval(check);

      // Use the official visit_count API with CSS selector
      window.goatcounter.visit_count({
        append: ".view-count",
        type: "html",
        no_branding: true,
        path: slug,
        style: "",
        attr: { style: "" },
      });

      // Show the element once visit_count has populated it
      const show = setInterval(() => {
        if (countEl.textContent && countEl.textContent.trim() !== "") {
          el.classList.remove("hidden");
          el.classList.add("flex");
          clearInterval(show);
        }
      }, 200);

      // Stop checking after 5s
      setTimeout(() => clearInterval(show), 5000);
    }, 100);

    // Stop polling after 5s if count.js never loads
    setTimeout(() => clearInterval(check), 5000);
  }

  document.addEventListener("astro:page-load", initViewCounters);
</script>
